# Copy to .env and adjust. All keys are prefixed GOFORGE_ in code (see config.py).

# Local sandbox (default: repo-root sandbox-repo)
# GOFORGE_REPO_ROOT=/absolute/path/to/sandbox-repo

# Optional: OpenAI-compatible planner (Chat Completions JSON)
# GOFORGE_OPENAI_API_KEY=
# GOFORGE_OPENAI_BASE_URL=https://api.openai.com/v1
# GOFORGE_OPENAI_MODEL=gpt-4o-mini
# GOFORGE_PLANNER_TIMEOUT_S=120
# GOFORGE_CODEGEN_TIMEOUT_S=180
# GOFORGE_VALIDATION_MAX_ATTEMPTS=3

# Optional: GitHub PR (after validation). Requires repo remote on github.com or push URL derived from owner/name.
# GOFORGE_GITHUB_TOKEN=
# GOFORGE_GITHUB_REPO=owner/repo
# GOFORGE_GITHUB_DEFAULT_BRANCH=
